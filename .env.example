# Strapi (CMS) genel adresi
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# toptan3dcim-backend (Strapi) genel adresi - checkout sayfası ödeme
# başlatma isteğini (POST /api/payment/initiate) bu adrese gönderir.
NEXT_PUBLIC_BACKEND_URL=http://localhost:1337

# Kart ile ödeme (checkout) özelliğini açar/kapatır. "true" değilse sepetteki
# "Kart ile Öde" butonu render edilmez ve /checkout sayfasına erişim engellenir.
NEXT_PUBLIC_PAYMENTS_ENABLED=false
